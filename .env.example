# NANDIA — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs

# Symfony
APP_ENV=dev

# Database
DATABASE_URL=pgsql://postgres:password@database:5432/backend_db
CORS_ALLOW_ORIGIN=https://localhost:8443,https://localhost:3000,https://127.0.0.1:3000

# PostgreSQL
POSTGRES_DB=backend_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=YOUR_PGADMIN_PASSWORD

# JWT (générer avec : php bin/console lexik:jwt:generate-keypair)
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=YOUR_JWT_PASSPHRASE

# OneSignal (Dashboard → App Settings → Keys & IDs)
ONESIGNAL_APP_ID=YOUR_ONESIGNAL_APP_ID
ONESIGNAL_REST_API_KEY=YOUR_ONESIGNAL_REST_API_KEY

# Mailer
# Options : Mailtrap (dev), Gmail, SendGrid, Mailgun...
MAILER_DSN=YOUR_MAILER_DSN
MAILER_FROM_EMAIL=YOUR_SENDER_EMAIL
MAILER_FROM_NAME=Nandia
