# Symfony
APP_ENV=dev
APP_SECRET=changeme_replace_with_64_hex_chars_openssl_rand_hex_32
DEFAULT_URI=pgsql://postgres:postgres@database:5432/backend_db
DATABASE_URL=pgsql://postgres:postgres@database:5432/backend_db
CORS_ALLOW_ORIGIN=https://localhost:8443,https://localhost:3000,https://127.0.0.1:3000

# PostgreSQL
# (local overrides in .env.local)
POSTGRES_DB=backend_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# PgAdmin
# (local overrides in .env.local)
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=changeme

# Ports
SYMFONY_HTTP_PORT=8000
SYMFONY_HTTPS_PORT=8443
POSTGRES_PORT=5449
PGADMIN_PORT=5050

###< lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=changeme # (local overrides in .env.local)

# OneSignal — Push Notifications
# Récupérer dans OneSignal Dashboard → App Settings → Keys & IDs
ONESIGNAL_APP_ID=8897cb87-807a-4dca-8ce7-9a79c2200001
ONESIGNAL_REST_API_KEY=changeme # (local overrides in .env.local)

# Mailer — Envoi des emails (reset de mot de passe, etc.)
# Dev rapide  : créer un compte sur https://mailtrap.io → SMTP Inbox → credentials
# Gmail       : MAILER_DSN=gmail://votre@gmail.com:app_password@default
# SendGrid    : MAILER_DSN=sendgrid+smtp://CLE_API@default
# Mailgun     : MAILER_DSN=mailgun+smtp://KEY:DOMAIN@default
###> symfony/mailer ###
# MAILER_DSN=smtp://localhost:1025 :opzo fpwv wrmk zjfe
# (local overrides in .env.local)
###< symfony/mailer ###
MAILER_FROM_EMAIL=lieloumloum@gmail.com
MAILER_FROM_NAME=Nandia

###> symfony/mercure-bundle ###
# See https://symfony.com/doc/current/mercure.html#configuration
# The URL of the Mercure hub, used by the app to publish updates (can be a local URL)
MERCURE_URL=https://example.com/.well-known/mercure
# The public URL of the Mercure hub, used by the browser to connect
MERCURE_PUBLIC_URL=https://example.com/.well-known/mercure
# The secret used to sign the JWTs
MERCURE_JWT_SECRET="!ChangeThisMercureHubJWTSecretKey!"
###< symfony/mercure-bundle ###

# Sentry / GlitchTip — crash reporting (laisser vide pour désactiver)
SENTRY_DSN=

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###
