# Symfony
APP_ENV=dev
DEFAULT_URI=pgsql://postgres:postgres@database:5432/backend_db
DATABASE_URL=pgsql://postgres:postgres@database:5432/backend_db
CORS_ALLOW_ORIGIN=https://localhost:8443

# PostgreSQL
POSTGRES_DB=backend_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin

# Ports
SYMFONY_HTTP_PORT=8000
SYMFONY_HTTPS_PORT=8443
POSTGRES_PORT=5449
PGADMIN_PORT=5050

###< lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=31a710b4092108d3d253ae000df8c505df3457b0150888a952e7f6fe68dc35e4